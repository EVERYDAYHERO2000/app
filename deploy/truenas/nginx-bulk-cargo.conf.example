# Пример для nginx на TrueNAS SCALE: статика фронта + прокси /api -> backend.
# Скопируйте в /etc/nginx/sites-available/ и сделайте symlink в sites-enabled,
# или включите из conf.d. Подставьте root и server_name.
#
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 8080;
    server_name _;

    root /ABS/PATH/TO/app/frontend/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:3001/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
