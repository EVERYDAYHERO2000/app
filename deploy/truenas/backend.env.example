# Скопируйте на сервер как backend/.env и подставьте свои значения.
# Путь к SQLite: каталог prisma внутри backend (файл создастся автоматически).
NODE_ENV=production
PORT=3001
DATABASE_URL="file:./prisma/prod.db"
SESSION_SECRET=замените-на-длинную-случайную-строку

# Публичный URL фронта (для CORS и cookie). Пример:
# FRONTEND_URL=https://bulk-cargo.example.com
# или http://192.168.1.50
FRONTEND_URL=http://127.0.0.1:8080

# OAuth Yandex — если используете на тесте
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_CALLBACK_URL=https://ваш-домен/auth/yandex/callback
